# Enable Rewrite Engine
RewriteEngine On
RewriteBase /Assets/

# Redirect to custom 404 page
ErrorDocument 404 /Assets/404.html

# Redirect to custom 500 page
ErrorDocument 500 /Assets/500.html

# Serve offline.html if offline
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^offline$ /Assets/offline.html [L]

# Prevent access to sensitive backend scripts (optional)
<FilesMatch "(\.sql|\.tpl|\.ini|\.log|\.sh|_conn\.php|setup_admin\.php)">
  Order allow,deny
  Deny from all
</FilesMatch>

# Cache PWA static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# Force UTF-8 Encoding
AddDefaultCharset utf-8
