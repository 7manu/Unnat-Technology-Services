              },
              ".content-wrap": {
                ".mbr-desc": {
                  "margin-bottom": "24px"
                },
                ".mbr-section-title": {
                  "margin-bottom": "32px"
                }
              }
            },
            ".item": {
              "padding": "48px 32px",
              "background-color": "@card_1",
              "position": "relative",
              "min-height": "260px",
              "overflow": "hidden",
              "width": "85%",
              "transform": "rotate(-2deg)",
              "margin-top": "-1rem",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "bottom": "-4rem",
                "right": "-12rem",
                "border": "20px solid @decor",
                "opacity": ".6",
                "width": "100%",
                "height": "50%",
                "border-radius": "100%"
              },
              "&:first-child": {
                "margin-top": "0"
              },
              "&:nth-child(2n)": {
                "background-color": "@card_2",
                "margin-left": "40px",
                "transform": "rotate(2deg)",
                "@media (max-width: 992px)": {
                  "margin-left": "0"
                }
              },
              "&:nth-child(3n)": {
                "background-color": "@card_3"
              },
              "&:nth-child(4n)": {
                "background-color": "@card_4"
              },
              "@media (max-width: 992px)": {
                "width": "100%",
                "padding": "24px 16px",
                "margin-left": "0"
              },
              ".item-wrapper": {
                ".card-box": {
                  ".card-title_1, .card-title_2, .card-title_3, .card-title_4": {
                    "margin-bottom": "0"
                  }
                }
              }
            },
            ".mbr-desc": {
              "color": "#fb8600"
            },
            ".mbr-section-title": {
              "color": "#000000"
            },
            ".card-title_1": {
              "color": "#000000"
            },
            ".card-title_2": {
              "color": "#ffffff"
            },
            ".card-title_3": {
              "color": "#ffffff"
            },
            ".card-title_4": {
              "color": "#ffffff"
            }
          },
          "_name": "features03",
          "_sourceTheme": "aspectm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"features03 aspectm5\" group=\"Features\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Description\" name=\"showDesc\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <header>Cards</header>\n        <input type=\"color\" title=\"Card BG 1\" value=\"#fcea75\" name=\"card_1\" selected>\n        <input type=\"color\" title=\"Card BG 2\" value=\"#ecce0d\" name=\"card_2\" selected>\n        <input type=\"color\" title=\"Card BG 3\" value=\"#fbac00\" name=\"card_3\" selected>\n        <input type=\"color\" title=\"Card BG 4\" value=\"#fb8600\" name=\"card_4\" selected>\n        <input type=\"color\" title=\"Decor Color\" value=\"#ffffff\" name=\"decor\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/aspectm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/aspectm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5\">\n                <div class=\"content-wrapper\">\n                    <div class=\"content-wrap\">\n                        <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showDesc\" data-app-selector=\".mbr-desc\">\n                            Industry Expertise</p>\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title, .mbr-section-btn\">Unnat Technology Services caters to a wide range of industries, including -&nbsp;</h2>\n                    </div>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"contact.html\" data-app-placeholder=\"Type Text\">CONTACT US</a></div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5\">\n                <div class=\"items-wrapper\">\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title_1 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title_1\">\n                                    Healthcare\n                                </h4>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title_2 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title_2\">Retail and E-commerce</h4>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title_3 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title_3\">\n                                    Education\n                                </h4>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"item features-without-image item-mb\">\n                        <div class=\"item-wrapper\">\n                            <div class=\"card-box\">\n                                <h4 class=\"card-title_4 mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".card-title_4\">Government and Public Sector</h4>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "ufKUSUvMrG",
          "_anchor": "features03-8",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "article2",
          "_sourceTheme": "estatem5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"article2\" group=\"Article\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"range\" name=\"textWidth\" title=\"Width\" min=\"4\" max=\"12\" value=\"12\" step=\"1\">\n        <input type=\"color\" name=\"lineColor\" title=\"Line Color\" value=\"#fbda00\">\n        <input type=\"color\" name=\"cardColor\" title=\"Color\" value=\"#f7f7f7\">\n        <header>Background</header>\n        <input type=\"color\" title=\"Color\" name=\"bgColor\" value=\"#edefeb\">\n    </mbr-parameters>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n            <div class=\"col-12 col-md-{{textWidth}} text-center\">\n                <blockquote>\n                    <h5 class=\"mbr-section-title mbr-fonts-style mb-lg-4 mb-md-4 mb-sm-4\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Commitment to Excellence<div><br></div></h5>\n                    <p class=\"mbr-text mbr-fonts-style mt-2\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text\">\n                        Unnat Technology Services is committed to delivering high-quality solutions tailored to meet the unique needs of each client. The company's approach is customer-centric, ensuring that every project is aligned with the client's strategic goals. With a team of highly skilled professionals, Unnat Technology Services combines technical expertise with deep industry knowledge to provide solutions that drive business success.\n                    </p>\n                    <div class=\"geometry geometry_bottom-left\">\n                        <div class=\"geometry__square\"></div>\n                        <div class=\"geometry__square-bg\"></div>\n                    </div>\n                </blockquote>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "background-color": "@bgColor",
            ".geometry": {
              "position": "absolute",
              "&__triangle": {
                "width": "128px",
                "height": "88px"
              },
              "&_left": {
                "left": "-70px"
              },
              "&__square": {
                "width": "88px",
                "height": "88px",
                "border-radius": "100px",
                "border": "2px solid #0b2b5c",
                "padding": "-1rem",
                "z-index": "1",
                "position": "absolute"
              },
              "&__square-bg": {
                "position": "absolute",
                "width": "88px",
                "height": "88px",
                "background": "@secondaryColor",
                "border-radius": "100px",
                "margin": "0.5rem"
              },
              "&_bottom-left": {
                "left": "140px",
                "bottom": "40px"
              }
            },
            "blockquote": {
              "border-color": "@lineColor",
              "border-radius": "34px",
              "margin": "0",
              "background-color": "@cardColor",
              "h5": {
                "font-weight": "300"
              }
            },
            "@media (max-width: 992px)": {
              "blockquote": {
                "padding": "2rem 1rem"
              },
              ".geometry": {
                "position": "absolute",
                "&__square, &__square-bg": {
                  "width": "66px",
                  "height": "66px"
                },
                "&_bottom-left": {
                  "left": "140px",
                  "bottom": "40px"
                }
              }
            },
            "@media (min-width: 992px)": {
              "blockquote": {
                "padding": "3rem"
              }
            },
            "@media (max-width: 1400px)": {
              ".box-shadow": {
                "padding": "3rem 10rem"
              }
            },
            "@media (max-width: 1200px)": {
              ".box-shadow": {
                "padding": "3rem 5rem"
              }
            },
            "@media (max-width: 767px)": {
              "blockquote": {
                "padding": "2rem 1rem"
              }
            },
            "@media (min-width: 768px)": {
              ".geometry__square-bg": {
                "transition": "transform .3s",
                "transform-origin": "0 60px"
              },
              "blockquote": {
                "&:hover": {
                  ".geometry__square-bg": {
                    "transform": "rotate(-40deg) scale(0.9)"
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#fb8600"
            },
            ".mbr-text": {
              "text-align": "left"
            }
          },
          "_cid": "ufL43NROL3",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "article2-f"
        },
        {
          "_name": "content9",
          "_sourceTheme": "leaderm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content9\" group=\"Content\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"1\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Circles 1\" name=\"showCircle_1\" checked>\n        <input type=\"color\" title=\"Circle Color 1\" name=\"circle_1\" value=\"#fb8600\" condition=\"showCircle_1\" selected>\n        <input type=\"checkbox\" title=\"Circles 2\" name=\"showCircle_2\" checked>\n        <input type=\"color\" title=\"Circle Color 2\" name=\"circle_2\" value=\"#ecce0d\" condition=\"showCircle_2\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" parallax>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 image\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/image4.jpg\" alt=\"UTS\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"text-wrapper\">\n                    <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Innovation and R&amp;D</b></h2>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">Innovation is at the heart of Unnat Technology Services. The company invests significantly in research and development to stay ahead of technological advancements and industry trends. This commitment to innovation ensures that clients receive cutting-edge solutions that provide a competitive edge in the market.<br><br></p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "padding": "0 110px",
              "@media (max-width: 992px)": {
                "padding": "0 12px"
              }
            },
            ".text-wrapper": {
              "padding": "25px",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              ".mbr-section-title": {
                "margin-bottom": "15px",
                "span": {
                  "color": "@secondaryColor"
                }
              },
              ".mbr-text": {
                "margin-bottom": "16px"
              }
            },
            ".image": {
              "position": "relative",
              "& when (@showCircle_2)": {
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "3rem",
                  "left": "0",
                  "width": "155px",
                  "height": "155px",
                  "background-color": "transparent",
                  "border-radius": "100%",
                  "border": "20px solid @circle_2",
                  "& when not (@reverseContent)": {
                    "left": "auto",
                    "right": "0"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "5.93rem",
                  "left": "3rem",
                  "width": "60px",
                  "height": "60px",
                  "background-color": "@circle_2",
                  "border-radius": "100%",
                  "& when not (@reverseContent)": {
                    "left": "auto",
                    "right": "3rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              }
            },
            ".image-wrapper": {
              "position": "relative",
              "padding-top": "50%",
              "width": "fit-content",
              "@media (max-width: 992px)": {
                "padding": "0",
                "display": "flex",
                "justify-content": "center",
                "margin-bottom": "25px",
                "width": "auto"
              },
              "& when (@showCircle_1)": {
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "right": "-20rem",
                  "top": "13rem",
                  "display": "block",
                  "width": "400px",
                  "height": "400px",
                  "border": "30px solid @circle_1",
                  "border-radius": "50%",
                  "background-color": "transparent",
                  "z-index": "5",
                  "& when not (@reverseContent)": {
                    "right": "auto",
                    "left": "-20rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "position": "absolute",
                  "right": "-26rem",
                  "top": "6.7rem",
                  "display": "block",
                  "width": "600px",
                  "height": "600px",
                  "border": "30px solid @circle_1",
                  "border-radius": "50%",
                  "background-color": "transparent",
                  "z-index": "1",
                  "& when not (@reverseContent)": {
                    "right": "auto",
                    "left": "-26rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              },
              "img": {
                "width": "400px",
                "min-height": "600px",
                "border-radius": "0 0 0 100%",
                "z-index": "2",
                "position": "relative",
                "& when not (@reverseContent)": {
                  "border-radius": "0 0 100% 0"
                },
                "@media (max-width: 992px)": {
                  "min-height": "auto",
                  "width": "250px"
                }
              }
            },
            ".mbr-section-title": {
              "color": "#fb8600"
            },
            ".mbr-text": {
              "color": "#000000"
            }
          },
          "_cid": "ufLbqafAK3",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "content9-h"
        },
        {
          "_name": "content10",
          "_sourceTheme": "leaderm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content10\" group=\"Content\" mbr-class=\"{'mbr-fullscreen': fullScreen,\n                    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"0\" condition=\"fullScreen == false\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"2\" condition=\"fullScreen == false\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Decoration\" name=\"decor\" checked>\n        <input type=\"color\" title=\"Color 1\" name=\"decor_1\" value=\"#fb8600\" condition=\"decor\" selected>\n        <input type=\"color\" title=\"Color 2\" name=\"decor_2\" value=\"#fcea75\" condition=\"decor\" selected>\n        <input type=\"checkbox\" title=\"Circle\" name=\"showCircle\" checked>\n        <input type=\"color\" title=\"Circle Color 1\" value=\"#fb8600\" name=\"circle_1\" condition=\"showCircle\" selected>\n        <input type=\"color\" title=\"Circle Color 2\" value=\"#fcea75\" name=\"circle_2\" condition=\"showCircle\" selected>\n        <input type=\"color\" title=\"Container\" value=\"#ffffff\" name=\"container\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" parallax>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/leaderm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.7\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div mbr-class=\"{'container': !fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-6 image\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/mbr-843x562.jpg\" alt=\"CSR\">\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-6\">\n                <div class=\"text-wrapper\">\n                    <h3 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>Sustainability and </b><br><b>Social Responsibility</b></h3>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text\">\n                        Unnat Technology Services is dedicated to sustainable business practices and corporate social responsibility. The company actively engages in initiatives that promote environmental sustainability, community development, and education.</p>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".row": {
              "padding": "0 110px",
              "position": "relative",
              "&::before": {
                "content": "''",
                "position": "absolute",
                "top": "-5rem",
                "right": "0",
                "display": "block",
                "width": "45%",
                "height": "140%",
                "background-color": "@container",
                "border-radius": "0 0 100% 0",
                "& when (@reverseContent)": {
                  "right": "auto",
                  "left": "0",
                  "border-radius": "0 0 0 100%"
                },
                "@media (max-width: 992px)": {
                  "display": "none"
                }
              },
              "@media (max-width: 992px)": {
                "padding": "0 12px"
              }
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".image": {
              "position": "relative",
              "& when (@decor)": {
                "&::before": {
                  "content": "''",
                  "display": "block",
                  "background-color": "@decor_1",
                  "position": "absolute",
                  "top": "-4rem",
                  "left": "6rem",
                  "width": "100px",
                  "height": "100px",
                  "z-index": "2",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "6rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "display": "block",
                  "background-color": "@decor_2",
                  "position": "absolute",
                  "top": "-2.7rem",
                  "left": "7.3rem",
                  "width": "60px",
                  "height": "60px",
                  "border-radius": "0 100% 0 0",
                  "z-index": "3",
                  "& when (@reverseContent)": {
                    "left": "auto",
                    "right": "7.3rem",
                    "border-radius": "100% 0 0 0"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              }
            },
            ".image-wrapper": {
              "position": "relative",
              "padding-right": "85px",
              "& when (@reverseContent)": {
                "padding-right": "0",
                "padding-left": "85px",
                "@media (max-width: 992px)": {
                  "padding": "0",
                  "display": "flex",
                  "justify-content": "center"
                }
              },
              "@media (max-width: 992px)": {
                "padding": "0",
                "display": "flex",
                "justify-content": "center"
              },
              "img": {
                "max-width": "100%",
                "max-height": "360px",
                "object-fit": "cover",
                "border-radius": "0 0 0 75%",
                "z-index": "1",
                "position": "relative",
                "& when (@reverseContent)": {
                  "border-radius": "0 0 75% 0"
                }
              },
              "& when (@showCircle)": {
                "&::before": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "3rem",
                  "right": "0",
                  "width": "155px",
                  "height": "155px",
                  "background-color": "transparent",
                  "border-radius": "100%",
                  "border": "20px solid @circle_1",
                  "& when (@reverseContent)": {
                    "right": "auto",
                    "left": "0"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                },
                "&::after": {
                  "content": "''",
                  "position": "absolute",
                  "bottom": "5.93rem",
                  "right": "3rem",
                  "width": "60px",
                  "height": "60px",
                  "background-color": "@circle_2",
                  "border-radius": "100%",
                  "& when (@reverseContent)": {
                    "right": "auto",
                    "left": "3rem"
                  },
                  "@media (max-width: 992px)": {
                    "display": "none"
                  }
                }
              }
            },
            ".text-wrapper": {
              "padding-left": "40px",
              "position": "relative",
              "z-index": "1",
              "@media (max-width: 992px)": {
                "padding": "0"
              },
              "& when (@reverseContent)": {
                "padding-left": "0",
                "padding-right": "40px",
                "@media (max-width: 992px)": {
                  "padding": "0"
                }
              },
              ".mbr-section-title": {
                "margin-bottom": "10px",
                "@media (max-width: 992px)": {
                  "margin": "10px 0"
                }
              },
              ".mbr-text": {
                "margin-bottom": "0"
              }
            },
