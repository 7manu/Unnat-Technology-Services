        {
          "_name": "content4",
          "_sourceTheme": "restaurantm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"mbr-section article content4 restaurantm4_content4\" group=\"Content\">\n\n\t<mbr-parameters>\n\t\t<!-- Block parameters controls (Blue \"Gear\" panel) -->\n\t\t<header>Size</header>\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"5\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n\t\t<header>Show / Hide</header>\n\t\t<input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Stylized Counters\" name=\"stylizedCounters\">\n\t\t<input type=\"checkbox\" title=\"Square Counters\" name=\"squareCounters\" condition=\"stylizedCounters\">\n\t\t<header>Colors</header>\n\t\t<input type=\"color\" title=\"Counter Bg\" name=\"counterColor\" value=\"#ffda73\" condition=\"stylizedCounters\">\n\t\t<input type=\"color\" title=\"Background\" name=\"bgColor\" value=\"#f9e2af\">\n\t\t<input type=\"checkbox\" title=\"Gradient Background\" name=\"gradientBg\" checked>\n\t\t<input type=\"color\" title=\"Background 2\" name=\"bgColor2\" value=\"#edefeb\" condition=\"gradientBg\">\n\t\t<!-- End block parameters -->\n\t</mbr-parameters>\n\n\t<div class=\"container\">\n\t\t<div class=\"row justify-content-center\">\n\t\t\t<h2 class=\"mbr-section-title col-12 col-md-8 mbr-fonts-style align-center pb-3\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n\t\t\t\tOur Vision</h2>\n\t\t\t<div class=\"mbr-text counter-container col-12 col-md-8 mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text\" data-multiline mbr-article>\n\t\t\t\t\tUnnat Technology Services is a dynamic and forward-thinking technology solutions provider, committed to helping businesses navigate the complexities of the digital age. With a comprehensive suite of services and a focus on innovation and excellence, Unnat Technology Services is poised to be a leader in the technology landscape of India and beyond.\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "background-color": "@bgColor",
            "& when (@gradientBg)": {
              "background": "linear-gradient(0deg, @bgColor, @bgColor2)"
            },
            ".counter-container": {
              "color": "#444444",
              "ol": {
                "margin-bottom": "0",
                "li": {
                  "margin-bottom": "1rem"
                },
                "& when (@stylizedCounters)": {
                  "counter-reset": "myCounter",
                  "li": {
                    "list-style": "none",
                    "padding-left": "0.5rem",
                    "position": "relative",
                    "&:before": {
                      "position": "absolute",
                      "left": "-56px",
                      "margin-top": "-10px",
                      "counter-increment": "myCounter",
                      "content": "counter(myCounter)",
                      "display": "inline-block",
                      "text-align": "center",
                      "margin": "5px 10px",
                      "line-height": "35px",
                      "transition": "all 0.2s",
                      "color": "contrast(@counterColor)",
                      "background": "@counterColor",
                      "width": "40px",
                      "height": "40px",
                      "border-radius": "50%",
                      "& when (@squareCounters)": {
                        "border-radius": "0"
                      }
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#fb8600"
            }
          },
          "_cid": "ufLfpbXAOq",
          "_anchor": "content4-k",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "_name": "afooter2",
          "_sourceTheme": "stepm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer2 stepm5\" group=\"Footers\" global once=\"footers\" mbr-class=\"{'mbr-reveal': reveal, 'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"8\" step=\"1\" value=\"2\">\n        <input type=\"checkbox\" title=\"Reveal effect\" name=\"reveal\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/stepm5/components/_images/background3.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#dfc692\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#F5A80C\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.6\" condition=\"overlay && bg.type !== 'color'\">\n        <!-- End block parameters -->\n    </mbr-parameters>\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n    <div class=\"container\">\n        <div class=\"media-container-row align-center mbr-white\">\n            <div class=\"col-12\">\n                <p class=\"mbr-text mb-0 mbr-fonts-style align-center\" mbr-theme-style=\"display-4\" data-app-selector=\".media-container-row .mbr-text\" data-app-placeholder=\"Type Text\">\n                    © Copyright 2024 UTS - All Rights Reserved\n                </p>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-text": {
              "color": "#FFFFFF"
            }
          },
          "_cid": "ufLgx16h1z",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {},
          "_anchor": "afooter2-l"
        }
      ]
    },
    "contact.html": {
      "settings": {
        "title": "Contact Us",
        "order": "4"
      },
      "components": [
        {
          "_name": "menu1",
          "_sourceTheme": "recruiterm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu1 menu\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" global always-top position-absolute once=\"menu\">\n\n\t<mbr-parameters>\n\t\t<!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Position</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Show Logo\" name=\"showLogo\" checked>\n\t\t<input type=\"checkbox\" title=\"Show Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Show Menu Items\" name=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Show Icons\" name=\"showIcons\" condition=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Show Contact(s)\" name=\"showContacts\" condition=\"showItems\" checked>\n        <header>Size</header>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"5\" step=\"0.1\" value=\"3\" condition=\"showLogo\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"6\">2</option>\n            <option value=\"4\" selected>3</option>\n        </select>\n\t\t<select title=\"Icons\" name=\"iconsAmount\" condition=\"showIcons&&showItems\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\">3</option>\n\t\t\t<option value=\"4\">4</option>\n\t\t\t<option value=\"5\">5</option>\n\t\t\t<option value=\"6\" selected>6</option>\n\t\t</select>\n        <header>Color</header>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#00aeb0\" condition=\"showIcons\">\n        <input type=\"color\" title=\"Items Hover Color\" name=\"itemsHoverColor\" value=\"#fbac00\" condition=\"showItems\">\n\t\t<input type=\"color\" title=\"Hamburger Color\" name=\"hamburgerColor\" value=\"#fbac00\">\n\t\t<input type=\"color\" title=\"Background Color\" name=\"menuBgColor\" value=\"#fffbe3\">\n\t\t<!-- End block parameters -->\n\t</mbr-parameters>\n\n        <nav class=\"navbar navbar-dropdown collapsed b-shadow\" mbr-class=\"{'navbar-fixed-top':sticky}\">\n            <div class=\"container\">\n                \n\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems\">\n\t\t\t<div class=\"hamburger\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\t\t</button>\n                <div class=\"navbar-brand\">\n\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t<a href=\"index.html\">\n\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/mbr-100x99.png\" alt=\"UTS\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t</a>\n\t\t\t</span>\n\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\"><a class=\"navbar-caption text-black text-primary\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">UNNAT TECHNOLOGY SERVICES</a></span>\n\t\t</div>\n\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n\t\t\t<div class=\"flex-container\">\n\t\t\t\t<div class=\"flex-row\">\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\">\n                                        <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">CONTACT US</h6>\n\t\t\t\t\t\t<ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"https://maps.app.goo.gl/nB6VPkdqmEcwCJhh6\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">Address:&nbsp; Buddhi Vihar, Delhi Road<br>Moradabad, 244001 UP</a> <a class=\"nav-link link text-black text-primary\" href=\"tel:9690805228\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">&nbsp;Call:&nbsp; 9690805228</a>   \n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"mailto:unnattechnologyservices@gmail.com\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">&nbsp;Email:&nbsp; unnattechnologyservices@gmail.com</a>  \n\t\t\t\t\t\t\t</li></ul></div>\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\" mbr-if=\"cardsAmount > 1\">\n                    <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">IMPORTANT LINKS</h6>\n                        <ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Home</a>   \n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"contact.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Contact Us</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t <a class=\"nav-link link text-black text-primary\" href=\"products.php\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Our Products</a>                          \n\t\t\t\t\t\t\t</li></ul></div>\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\" mbr-if=\"cardsAmount == 4\">\n                    <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">ABOUT US</h6>\n                        <ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#aheader2-6\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Who we are ?</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#features03-8\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Industry Expertise</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#content9-h\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Innovation and R&amp;D</a>  <a class=\"nav-link link text-black text-primary\" href=\"index.html#content4-k\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Our Vision</a>\n\t\t\t\t\t\t\t</li></ul></div>\n                </div>\n                \n                \n\n                \n                \n                <div class=\"flex-row low-row\">\n\t\t\t\t\t\t<div class=\"contact-block navbar-contacts align-right\" mbr-if=\"showContacts\">\n\t\t\t\t\t\t\t<ul class=\"mbr-fonts-style contact-list\" mbr-theme-style=\"display-4\" data-multiline mbr-text data-app-selector=\".icons-menu,.navbar-buttons,.contact-block,.text-column\">\n\t\t\t\t\t\t\t\t<li>&nbsp;</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t\t\t\t<a href=\"https://twitter.com/servicesunnat\" target=\"_blank\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont fa-twitter fa\" style=\"color: rgb(12, 205, 208); fill: rgb(12, 205, 208);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.facebook.com/Servicesunnat/\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(5, 117, 119); fill: rgb(5, 117, 119);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.youtube.com/channel/UC6FqgaWms6XvOnA-ArKPkxg\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-youtube socicon\" style=\"color: rgb(249, 44, 80); fill: rgb(249, 44, 80);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.instagram.com/servicesunnat/?hl=en\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(215, 0, 129); fill: rgb(215, 0, 129);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"mailto:unnattechnologyservices@gmail.com\" mbr-if=\"iconsAmount > 4\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-mail socicon\" style=\"color: rgb(255, 0, 0); fill: rgb(255, 0, 0);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.linkedin.com/company/unnat-technology-services\" target=\"_blank\" mbr-if=\"iconsAmount > 5\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\" style=\"color: rgb(0, 161, 164); fill: rgb(0, 161, 164);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n        </div>\n            </div>\n\n\t</nav>\n</section>",
          "_styles": {
            ".b-shadow": {
              "box-shadow": "0 5px 5px 0 rgba(0, 0, 0, 0.05)"
            },
            ".nav-item": {
              "list-style": "none"
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".nav-dropdown .dropdown-menu": {
              "padding-top": "0"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "-webkit-transition": "all 0.25s ease-in-out",
              "-moz-transition": "all 0.25s ease-in-out",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-left": "-1.8rem",
                "padding-right": "1rem",
                "font-size": "inherit",
                "&:before": {
                  "display": "inline-block",
                  "-webkit-transform": "scale(1, 1)",
                  "transform": "scale(1, 1)",
                  "-webkit-transition": "all 0.25s ease-in-out",
                  "-moz-transition": "all 0.25s ease-in-out",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".collapsed": {
              ".dropdown .dropdown-menu .dropdown-item": {
                "padding": "0em 0em !important",
                "transition": "none",
                "margin": "0 !important"
              }
            },
            ".navbar": {
              "min-height": "77px",
              "transition": "all 0.3s",
              "flex-direction": "row !important",
              "background": "@menuBgColor",
              "&.opened": {
                "transition": "all 0.3s",
                "background": "@menuBgColor !important"
              },
              ".dropdown-item": {
                "padding": "0.235rem 1.5rem"
              },
              ".navbar-collapse": {
                "-webkit-align-items": "center",
                "align-items": "center",
                "-webkit-justify-content": "center",
                "justify-content": "center",
                "height": "100%",
                "> .container": {
                  "height": "100%"
                },
                "padding-top": "3rem",
                "padding-bottom": "3rem",
                "z-index": "1",
                "&.show, &.collapsing": {
                  "display": "block"
                },
                ".img-column": {
                  "img": {
                    "width": "100%"
                  }
                },
                ".text-column": {
                  "overflow": "auto",
                  "max-height": "~'calc(100vh - 7rem)'"
                },
                "& when not (@showItems)": {
                  "display": "none !important"
                },
                ".contact-list": {
                  "list-style-type": "none",
                  "margin": "0",
                  "padding": "0"
                }
              },
              "&:not(.navbar-short) .text-column when (@showLogo)": {
                "max-height": "~'calc(100vh - 4rem - @{logoSize}rem)'"
              },
              "&.collapsed": {
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  "text-align": "inherit",
                  "background": "transparent !important",
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle='dropdown-submenu']:after": {
                    "margin-left": "0.25rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "55%"
                  }
                },
                "ul.navbar-nav": {
                  "word-break": "break-word"
                },
                ".dropdown-menu .dropdown-item": {
                  "text-align": "inherit"
                },
                ".icons-menu": {
                  "padding-left": "0",
                  "padding-top": "0.5rem",
                  "padding-bottom": "0.5rem"
                }
              },
              "&.navbar-short": {
                "background": "@menuBgColor !important",
                "min-height": "60px",
                ".navbar-logo": {
                  "img": {
                    "height": "3rem !important",
                    "width": "auto"
                  }
                },
                ".navbar-brand": {
                  "padding": "0"
                }
              }
            },
            ".navbar-brand": {
              "min-height": "61px",
              "-webkit-flex-shrink": "0",
              "flex-shrink": "0",
              "-webkit-align-items": "center",
              "align-items": "center",
              "margin-right": "0",
              "padding": "0",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none",
                "img": {
                  "width": "auto"
                }
              }
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar-expand-lg .navbar-nav .nav-link": {
              "padding": "0"
            },
            ".nav-dropdown .link": {
              "margin": "0.2em 0em"
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin": "0",
              "&[aria-expanded='true']": {
                "margin": "0em 0em",
                "padding": "0.2em 0em"
              }
            },
            ".navbar.navbar-expand-lg .dropdown": {
              ".dropdown-menu": {
                "background": "@menuBgColor",
                ".dropdown-submenu": {
                  "margin": "0",
                  "left": "100%"
                }
              }
            },
            ".socicon": {
              "transition": "color 0.3s"
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "block"
            },
            "ul.navbar-nav": {
              "-webkit-flex-wrap": "wrap",
              "flex-wrap": "wrap"
            },
            ".navbar-buttons": {
              "text-align": "inherit"
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "31px",
              "height": "20px",
              "cursor": "pointer",
              "transition": "all 0.2s",
              "position": "relative",
              "-webkit-align-self": "center",
              "align-self": "center",
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "width": "30px",
                "height": "2px",
                "border-right": "5px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "top": "0",
                  "transition": "all 0.2s"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "transition": "all 0.2s"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              },
              "&:nth-child(2)": {
                "-webkit-transform": "rotate(45deg)",
                "transform": "rotate(45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(3)": {
                "-webkit-transform": "rotate(-45deg)",
                "transform": "rotate(-45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              }
            },
            ".navbar-dropdown": {
              "padding": "0.5rem 1rem",
              "& when (@sticky)": {
                "position": "fixed"
              }
            },
            ".mbr-iconfont": {
              "font-size": "1.5rem",
              "padding-right": "0.5rem"
            },
            ".icons-menu": {
              "text-align": "inherit",
              "span": {
                "font-size": "20px",
                "color": "#232323"
              },
              "margin-right": "20px"
            },
            ".nav-link:hover, .dropdown-item:hover, .icons-menu .mbr-iconfont:hover": {
              "color": "@itemsHoverColor !important"
            },
            "@media screen and (~'-ms-high-contrast: active'), (~'-ms-high-contrast: none')": {
              ".navbar": {
                "height": "77px",
                "&.opened": {
                  "height": "auto"
                }
              }
            },
            "@media (max-width: 767px)": {
              ".navbar-collapse .img-column": {
                "display": "none"
              },
              ".icons-menu, .navbar-buttons, .contact-block, .text-column": {
                "text-align": "center !important"
              }
            },
            "h6.mbr-fonts-style": {
              "padding": "0"
            },
            ".collapsing": {
              "transition": "0s"
            },
            ".flex-container": {
              "height": "100%",
              "width": "100%"
            },
            "@media (min-width: 769px)": {
              ".flex-container": {
                "display": "flex",
                "flex-direction": "column"
              },
              ".flex-row": {
                "display": "flex",
                "flex-wrap": "wrap",
                "justify-content": "center",
                "width": "100%"
              },
              ".flex-row.low-row": {
                "align-items": "flex-end",
                "flex": "1 1 auto"
              },
              ".flex-card": {
                "display": "flex",
                "flex-direction": "column",
                "& h6": {
                  "padding": ".5rem 1rem"
                }
              },
              ".contact-block": {
                "margin-left": "20px"
              },
              ".contact-block ul li": {
                "text-align": "left"
              },
              "ul.col": {
                "padding": "0"
              },
              "& when (@showIcons) and (@showContacts)": {
                ".flex-row.low-row": {
                  "justify-content": "space-between"
                }
              }
            },
            ".icons-menu,.navbar-buttons,.contact-block,.text-column": {
              "color": "#000000"
            },
            "& when (@showIcons)": {
              ".icons-menu a span": {
                "color": "@iconsColor"
              }
            },
            "H6": {
              "color": "#fb8600",
              "text-align": "left"
            }
          },
          "_cid": "ufKLLFkzx1",
          "_anchor": "menu1-m",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "_name": "aform2",
          "_sourceTheme": "cookm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"form2\" group=\"Forms\" plugins=\"formstyler, datepicker\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Form Width\" name=\"formWidth\" min=\"3\" max=\"6\" step=\"1\" value=\"5\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Image Bg\" name=\"showImgBg\" checked>\n        <input type=\"color\" title=\"Image Bg Color\" name=\"imgBgColor\" value=\"#FCF0D5\" condition=\"showImgBg\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\">\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/cookm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n        </fieldset>\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#FEF9EE\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"hidden\" name=\"usedRecaptcha\" value=\"false\">\n    </mbr-parameters>\n    <div class=\"mbr-overlay\" mbr-if=\"(overlay && bg.type=='image')\"></div>\n    <div class=\"bg-img\" mbr-if=\"showImgBg\"></div>\n    <div class=\"container\">\n        <div class=\"mbr-section-head\" mbr-if=\"showTitle || showSubtitle\">\n            <h3 class=\"mbr-section-title mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-5\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">\n                <b>SEND YOUR QUERY</b></h3>\n            <h4 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0\" mbr-theme-style=\"display-4\" mbr-if=\"showSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                Enter Your Details</h4>\n        </div>\n        <div class=\"row justify-content-center\">\n            <div class=\"form-container\">\n                <div class=\"form-wrap\">\n                    <div mbr-form class=\"mbr-form\">\n                        <form action name=\"Form Name\" method=\"POST\" class=\"mbr-form form-with-styler mx-auto\">\n                          \n                            <div class=\"dragArea row\">\n                                <div class=\"col-12 form-group mb-3\" data-for=\"name\">\n                                    <label for=\"name\" class=\"form-control-label mbr-fonts-style display-7\" data-app-edit=\"content\" mbr-static-html=\"uname__40\" mbr-content-edit=\"uname__40\" data-app-placeholder=\"Type Text\" mbr-on-change-component-node=\"uname__41\" mbr-class-var=\"uname__42\" mbr-on-change-theme-style=\"uname__43\" data-class-var=\"display-7\">\n                                        Name\n                                    </label>\n                                    <input type=\"text\" name=\"name\" placeholder data-form-field=\"name\" class=\"form-control display-7\" value mbr-class-var=\"uname__44\" mbr-on-change-theme-style=\"uname__45\" data-class-var=\"display-7\">\n                                </div>\n\n                                <div class=\"col-12 form-group mb-3\" data-for=\"email\">\n                                    <label for=\"email\" class=\"form-control-label mbr-fonts-style display-7\" data-app-edit=\"content\" mbr-static-html=\"uname__40\" mbr-content-edit=\"uname__40\" data-app-placeholder=\"Type Text\" mbr-on-change-component-node=\"uname__41\" mbr-class-var=\"uname__42\" mbr-on-change-theme-style=\"uname__43\" data-class-var=\"display-7\">\n                                        Mobile\n                                    </label>\n                                    <input type=\"tel\" name=\"mobile\" placeholder data-form-field=\"email\" class=\"form-control display-7\" value mbr-class-var=\"uname__44\" mbr-on-change-theme-style=\"uname__45\" data-class-var=\"display-7\">\n                                </div>\n                                \n                                                                <div class=\"col-12 form-group mb-3\" data-for=\"email\">\n                                    <label for=\"email\" class=\"form-control-label mbr-fonts-style display-7\" data-app-edit=\"content\" mbr-static-html=\"uname__40\" mbr-content-edit=\"uname__40\" data-app-placeholder=\"Type Text\" mbr-on-change-component-node=\"uname__41\" mbr-class-var=\"uname__42\" mbr-on-change-theme-style=\"uname__43\" data-class-var=\"display-7\">\n                                        Email\n                                    </label>\n                                    <input type=\"email\" name=\"email\" placeholder data-form-field=\"email\" class=\"form-control display-7\" value mbr-class-var=\"uname__44\" mbr-on-change-theme-style=\"uname__45\" data-class-var=\"display-7\">\n                                </div>\n\n                                <div class=\"col-lg-12 col-md-12 col-sm-12 form-group mb-3\" data-for=\"question\">\n                                    <label for=\"question\" class=\"form-control-label mbr-fonts-style display-7\" data-app-edit=\"content\" mbr-static-html=\"uname__46\" mbr-content-edit=\"uname__46\" data-app-placeholder=\"Type Text\" mbr-on-change-component-node=\"uname__47\" mbr-class-var=\"uname__48\" mbr-on-change-theme-style=\"uname__49\" data-class-var=\"display-7\">\n                                        Your question\n                                    </label>\n                                    <textarea name=\"question\" placeholder data-form-field=\"question\" class=\"form-control display-7\" mbr-class-var=\"uname__50\" mbr-on-change-theme-style=\"uname__51\" data-class-var=\"display-7\"></textarea>\n                                </div>\n\n                                <div class=\"col-lg-12 col-md-12 col-sm-12 form-group mb-3\" data-for=\"details\">\n                                    <label for=\"details\" class=\"form-control-label mbr-fonts-style display-7\" data-app-edit=\"content\" mbr-static-html=\"uname__46\" mbr-content-edit=\"uname__46\" data-app-placeholder=\"Type Text\" mbr-on-change-component-node=\"uname__47\" mbr-class-var=\"uname__48\" mbr-on-change-theme-style=\"uname__49\" data-class-var=\"display-7\">\n                                        Details\n                                    </label>\n                                    <textarea name=\"details\" placeholder data-form-field=\"details\" class=\"form-control display-7\" mbr-class-var=\"uname__50\" mbr-on-change-theme-style=\"uname__51\" data-class-var=\"display-7\"></textarea>\n                                </div>\n                                <div class=\"col-auto mbr-section-btn align-center\" mbr-buttons=\"true\" mbr-theme-style=\"display-7\" data-toolbar=\"-mbrBtnMove,-mbrLink,-mbrBtnRemove,-mbrBtnAdd\"><a type=\"submit\" class=\"btn btn-primary\" data-app-placeholder=\"Type Text\"><span class=\"fa fa-send mbr-iconfont mbr-iconfont-btn\" style=\"color: rgb(251, 190, 54);\"></span>Send Details</a></div>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            ".mbr-overlay": {
              "background-color": "@overlayColor",
              "opacity": "@overlayOpacity"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            ".mbr-section-head": {
              "margin-bottom": "2rem"
            },
            ".mbr-section-title": {
              "color": "#ff7300"
            },
            ".mbr-section-subtitle": {
              "color": "#000000",
              "margin-top": "1rem"
            },
            ".form-container": {
              "display": "flex",
              "width": "100%"
            },
            ".form-wrap": {
              "max-width": "(@formWidth * 150px)",
              "width": "100%",
              "margin": "0 auto",
              "padding": "0 !important"
            },
            "form": {
              "width": "100%",
              ".dragArea.row": {
                "justify-content": "flex-start",
                "width": "auto !important"
              },
              "p": {
                "color": "#1F1D1A"
              },
              ".mbr-section-btn": {
                "margin-top": "0",
                "text-align": "center",
                "justify-content": "center",
                "margin-right": "auto",
                "@media (max-width: 767px)": {},
                ".btn": {
                  "min-width": "90px",
                  "padding": "9px 24px",
                  "border": "none !important"
                }
              },
              ".form-group": {
                "margin-top": "0 !important",
                "margin-bottom": "1.5rem !important"
              },
              ".form-control": {
                "height": "42px",
                "border": "1px solid #6b7280 !important",
                "background": "#ffffff",
                "box-shadow": "none !important",
                "border-radius": "0 !important",
                "margin-bottom": "0",
                "padding": "8px 12px",
                "font-size": "16px",
                "line-height": "24px",
                "color": "#1F1D1A",
                "font-weight": "400",
                "&::-webkit-input-placeholder": {
                  "color": "#bbbbbb"
                },
                "&::-moz-placeholder": {
                  "color": "#bbbbbb"
                },
                "&:-moz-placeholder": {
                  "color": "#bbbbbb"
                },
                "&:-ms-input-placeholder": {
                  "color": "#bbbbbb"
                }
              },
              "select": {
                "color": "#bbbbbb !important"
              },
              "textarea": {
                "height": "250px !important"
              },
              "input, textarea": {
                "&:active, &:focus": {
                  "background-color": "#ffffff !important",
                  "border-color": "#2563eb !important",
                  "outline": "2px solid #2563eb !important",
                  "outline-offset": "-1px",
                  "&::-webkit-input-placeholder": {
                    "color": "#adadad"
                  },
                  "&::-moz-placeholder": {
                    "color": "#adadad"
                  },
                  "&:-moz-placeholder": {
                    "color": "#adadad"
                  },
                  "&:-ms-input-placeholder": {
                    "color": "#adadad"
                  }
                }
              },
              ".row": {
                "margin-left": "-5px !important",
                "margin-right": "-5px !important"
              },
              ".row [class*=col]": {
                "padding-left": "5px !important",
                "padding-right": "5px !important"
              },
              "label": {
                "width": "100%",
                "color": "#1F1D1A",
                "margin-bottom": "0.5rem"
              },
              ".form-check-input": {
                "border-color": "#6b7280 !important",
                "outline": "none !important",
                "box-shadow": "none !important",
                "background-color": "transparent !important",
                "&:focus, &:hover": {
                  "background-color": "transparent !important",
                  "border-color": "#1F1D1A !important"
                }
              },
              ".form-check-input:checked": {
                "border-color": "#1F1D1A !important",
                "background-color": "#1F1D1A !important"
              }
            },
            "position": "relative",
            "overflow": "hidden",
            ".bg-img": {
              "position": "absolute",
              "width": "100%",
              "background-color": "@imgBgColor",
              "aspect-ratio": "(1 / 1)",
              "border-radius": "9999px",
              "left": "0",
              "bottom": "0",
              "transform": "translateY(50%)"
            }
          },
