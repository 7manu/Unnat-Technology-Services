      "components": [
        {
          "_name": "menu1",
          "_sourceTheme": "recruiterm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu1 menu\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" global always-top position-absolute once=\"menu\">\n\n\t<mbr-parameters>\n\t\t<!-- Block parameters controls (Blue \"Gear\" panel) -->\n        <header>Position</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\" checked>\n        <header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Show Logo\" name=\"showLogo\" checked>\n\t\t<input type=\"checkbox\" title=\"Show Brand Name\" name=\"showBrand\" checked>\n\t\t<input type=\"checkbox\" title=\"Show Menu Items\" name=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Show Icons\" name=\"showIcons\" condition=\"showItems\" checked>\n        <input type=\"checkbox\" title=\"Show Contact(s)\" name=\"showContacts\" condition=\"showItems\" checked>\n        <header>Size</header>\n\t\t<input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"3\" max=\"5\" step=\"0.1\" value=\"3\" condition=\"showLogo\">\n        <select title=\"Cards\" name=\"cardsAmount\">\n            <option value=\"6\">2</option>\n            <option value=\"4\" selected>3</option>\n        </select>\n\t\t<select title=\"Icons\" name=\"iconsAmount\" condition=\"showIcons&&showItems\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\">3</option>\n\t\t\t<option value=\"4\">4</option>\n\t\t\t<option value=\"5\">5</option>\n\t\t\t<option value=\"6\" selected>6</option>\n\t\t</select>\n        <header>Color</header>\n        <input type=\"color\" title=\"Icons Color\" name=\"iconsColor\" value=\"#00aeb0\" condition=\"showIcons\">\n        <input type=\"color\" title=\"Items Hover Color\" name=\"itemsHoverColor\" value=\"#fbac00\" condition=\"showItems\">\n\t\t<input type=\"color\" title=\"Hamburger Color\" name=\"hamburgerColor\" value=\"#fbac00\">\n\t\t<input type=\"color\" title=\"Background Color\" name=\"menuBgColor\" value=\"#fffbe3\">\n\t\t<!-- End block parameters -->\n\t</mbr-parameters>\n\n        <nav class=\"navbar navbar-dropdown collapsed b-shadow\" mbr-class=\"{'navbar-fixed-top':sticky}\">\n            <div class=\"container\">\n                \n\t\t<button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\" mbr-if=\"showItems\">\n\t\t\t<div class=\"hamburger\">\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t\t<span></span>\n\t\t\t</div>\n\t\t</button>\n                <div class=\"navbar-brand\">\n\t\t\t<span mbr-if=\"showLogo\" class=\"navbar-logo\">\n\t\t\t\t<a href=\"index.html\">\n\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/mbr-100x99.png\" alt=\"UTS\" mbr-style=\"{'height': logoSize + 'rem'}\">\n\t\t\t\t</a>\n\t\t\t</span>\n\t\t\t<span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-4\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\"><a class=\"navbar-caption text-black text-primary\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">UNNAT TECHNOLOGY SERVICES</a></span>\n\t\t</div>\n\t\t<div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n\t\t\t<div class=\"flex-container\">\n\t\t\t\t<div class=\"flex-row\">\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\">\n                                        <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">CONTACT US</h6>\n\t\t\t\t\t\t<ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"https://maps.app.goo.gl/nB6VPkdqmEcwCJhh6\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\" target=\"_blank\">Address:&nbsp; Buddhi Vihar, Delhi Road<br>Moradabad, 244001 UP</a> <a class=\"nav-link link text-black text-primary\" href=\"tel:9690805228\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">&nbsp;Call:&nbsp; 9690805228</a>   \n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"mailto:unnattechnologyservices@gmail.com\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">&nbsp;Email:&nbsp; unnattechnologyservices@gmail.com</a>  \n\t\t\t\t\t\t\t</li></ul></div>\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\" mbr-if=\"cardsAmount > 1\">\n                    <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">IMPORTANT LINKS</h6>\n                        <ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Home</a>   \n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"contact.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Contact Us</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t <a class=\"nav-link link text-black text-primary\" href=\"products.php\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Our Products</a>                          \n\t\t\t\t\t\t\t</li></ul></div>\n                    \n                                    <div class=\"flex-card col-12 col-md-6 col-lg-{{cardsAmount}}\" mbr-if=\"cardsAmount == 4\">\n                    <h6 class=\"mbr-fonts-style\" mbr-theme-style=\"display-7\">ABOUT US</h6>\n                        <ul class=\"col\" mbr-menu mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish&&!showBrand&&!showLogo}\"><li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#aheader2-6\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Who we are ?</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#features03-8\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Industry Expertise</a>\n\t\t\t\t\t\t\t</li>\n\t\t\t\t\t\t\t<li class=\"nav-item\">\n\t\t\t\t\t\t\t\t<a class=\"nav-link link text-black text-primary\" href=\"index.html#content9-h\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Innovation and R&amp;D</a>  <a class=\"nav-link link text-black text-primary\" href=\"index.html#content4-k\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Our Vision</a>\n\t\t\t\t\t\t\t</li></ul></div>\n                </div>\n                \n                \n\n                \n                \n                <div class=\"flex-row low-row\">\n\t\t\t\t\t\t<div class=\"contact-block navbar-contacts align-right\" mbr-if=\"showContacts\">\n\t\t\t\t\t\t\t<ul class=\"mbr-fonts-style contact-list\" mbr-theme-style=\"display-4\" data-multiline mbr-text data-app-selector=\".icons-menu,.navbar-buttons,.contact-block,.text-column\">\n\t\t\t\t\t\t\t\t<li>&nbsp;</li>\n\t\t\t\t\t\t\t</ul>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t\t<div class=\"icons-menu\" mbr-if=\"showIcons\">\n\t\t\t\t\t\t\t<a href=\"https://twitter.com/servicesunnat\" target=\"_blank\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont fa-twitter fa\" style=\"color: rgb(12, 205, 208); fill: rgb(12, 205, 208);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.facebook.com/Servicesunnat/\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\" style=\"color: rgb(5, 117, 119); fill: rgb(5, 117, 119);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.youtube.com/channel/UC6FqgaWms6XvOnA-ArKPkxg\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-youtube socicon\" style=\"color: rgb(249, 44, 80); fill: rgb(249, 44, 80);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.instagram.com/servicesunnat/?hl=en\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\" style=\"color: rgb(215, 0, 129); fill: rgb(215, 0, 129);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"mailto:unnattechnologyservices@gmail.com\" mbr-if=\"iconsAmount > 4\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-mail socicon\" style=\"color: rgb(255, 0, 0); fill: rgb(255, 0, 0);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t\t<a href=\"https://www.linkedin.com/company/unnat-technology-services\" target=\"_blank\" mbr-if=\"iconsAmount > 5\">\n\t\t\t\t\t\t\t\t<span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\" style=\"color: rgb(0, 161, 164); fill: rgb(0, 161, 164);\"></span>\n\t\t\t\t\t\t\t</a>\n\t\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n        </div>\n            </div>\n\n\t</nav>\n</section>",
          "_styles": {
            ".b-shadow": {
              "box-shadow": "0 5px 5px 0 rgba(0, 0, 0, 0.05)"
            },
            ".nav-item": {
              "list-style": "none"
            },
            ".nav-item:focus, .nav-link:focus": {
              "outline": "none"
            },
            ".nav-dropdown .dropdown-menu": {
              "padding-top": "0"
            },
            ".dropdown .dropdown-menu .dropdown-item": {
              "width": "auto",
              "-webkit-transition": "all 0.25s ease-in-out",
              "-moz-transition": "all 0.25s ease-in-out",
              "transition": "all 0.25s ease-in-out",
              "&::after": {
                "right": "0.5rem"
              },
              ".mbr-iconfont": {
                "margin-left": "-1.8rem",
                "padding-right": "1rem",
                "font-size": "inherit",
                "&:before": {
                  "display": "inline-block",
                  "-webkit-transform": "scale(1, 1)",
                  "transform": "scale(1, 1)",
                  "-webkit-transition": "all 0.25s ease-in-out",
                  "-moz-transition": "all 0.25s ease-in-out",
                  "transition": "all 0.25s ease-in-out"
                }
              }
            },
            ".collapsed": {
              ".dropdown .dropdown-menu .dropdown-item": {
                "padding": "0em 0em !important",
                "transition": "none",
                "margin": "0 !important"
              }
            },
            ".navbar": {
              "min-height": "77px",
              "transition": "all 0.3s",
              "flex-direction": "row !important",
              "background": "@menuBgColor",
              "&.opened": {
                "transition": "all 0.3s",
                "background": "@menuBgColor !important"
              },
              ".dropdown-item": {
                "padding": "0.235rem 1.5rem"
              },
              ".navbar-collapse": {
                "-webkit-align-items": "center",
                "align-items": "center",
                "-webkit-justify-content": "center",
                "justify-content": "center",
                "height": "100%",
                "> .container": {
                  "height": "100%"
                },
                "padding-top": "3rem",
                "padding-bottom": "3rem",
                "z-index": "1",
                "&.show, &.collapsing": {
                  "display": "block"
                },
                ".img-column": {
                  "img": {
                    "width": "100%"
                  }
                },
                ".text-column": {
                  "overflow": "auto",
                  "max-height": "~'calc(100vh - 7rem)'"
                },
                "& when not (@showItems)": {
                  "display": "none !important"
                },
                ".contact-list": {
                  "list-style-type": "none",
                  "margin": "0",
                  "padding": "0"
                }
              },
              "&:not(.navbar-short) .text-column when (@showLogo)": {
                "max-height": "~'calc(100vh - 4rem - @{logoSize}rem)'"
              },
              "&.collapsed": {
                "&.opened": {
                  ".dropdown-menu": {
                    "top": "0"
                  }
                },
                ".dropdown-menu": {
                  "text-align": "inherit",
                  "background": "transparent !important",
                  ".dropdown-submenu": {
                    "left": "0 !important"
                  },
                  ".dropdown-item:after": {
                    "right": "auto"
                  },
                  ".dropdown-toggle[data-toggle='dropdown-submenu']:after": {
                    "margin-left": "0.25rem",
                    "border-top": "0.35em solid",
                    "border-right": "0.35em solid transparent",
                    "border-left": "0.35em solid transparent",
                    "border-bottom": "0",
                    "top": "55%"
                  }
                },
                "ul.navbar-nav": {
                  "word-break": "break-word"
                },
                ".dropdown-menu .dropdown-item": {
                  "text-align": "inherit"
                },
                ".icons-menu": {
                  "padding-left": "0",
                  "padding-top": "0.5rem",
                  "padding-bottom": "0.5rem"
                }
              },
              "&.navbar-short": {
                "background": "@menuBgColor !important",
                "min-height": "60px",
                ".navbar-logo": {
                  "img": {
                    "height": "3rem !important",
                    "width": "auto"
                  }
                },
                ".navbar-brand": {
                  "padding": "0"
                }
              }
            },
            ".navbar-brand": {
              "min-height": "61px",
              "-webkit-flex-shrink": "0",
              "flex-shrink": "0",
              "-webkit-align-items": "center",
              "align-items": "center",
              "margin-right": "0",
              "padding": "0",
              "transition": "all 0.3s",
              "word-break": "break-word",
              "z-index": "1",
              ".navbar-caption": {
                "line-height": "inherit !important"
              },
              ".navbar-logo a": {
                "outline": "none",
                "img": {
                  "width": "auto"
                }
              }
            },
            ".dropdown-item.active, .dropdown-item:active": {
              "background-color": "transparent"
            },
            ".navbar-expand-lg .navbar-nav .nav-link": {
              "padding": "0"
            },
            ".nav-dropdown .link": {
              "margin": "0.2em 0em"
            },
            ".nav-dropdown .link.dropdown-toggle": {
              "margin": "0",
              "&[aria-expanded='true']": {
                "margin": "0em 0em",
                "padding": "0.2em 0em"
              }
            },
            ".navbar.navbar-expand-lg .dropdown": {
              ".dropdown-menu": {
                "background": "@menuBgColor",
                ".dropdown-submenu": {
                  "margin": "0",
                  "left": "100%"
                }
              }
            },
            ".socicon": {
              "transition": "color 0.3s"
            },
            ".navbar .dropdown.open > .dropdown-menu": {
              "display": "block"
            },
            "ul.navbar-nav": {
              "-webkit-flex-wrap": "wrap",
              "flex-wrap": "wrap"
            },
            ".navbar-buttons": {
              "text-align": "inherit"
            },
            "button.navbar-toggler": {
              "outline": "none",
              "width": "31px",
              "height": "20px",
              "cursor": "pointer",
              "transition": "all 0.2s",
              "position": "relative",
              "-webkit-align-self": "center",
              "align-self": "center",
              ".hamburger span": {
                "position": "absolute",
                "right": "0",
                "width": "30px",
                "height": "2px",
                "border-right": "5px",
                "background-color": "@hamburgerColor",
                "&:nth-child(1)": {
                  "top": "0",
                  "transition": "all 0.2s"
                },
                "&:nth-child(2)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(3)": {
                  "top": "8px",
                  "transition": "all 0.15s"
                },
                "&:nth-child(4)": {
                  "top": "16px",
                  "transition": "all 0.2s"
                }
              }
            },
            "nav.opened .hamburger span": {
              "&:nth-child(1)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              },
              "&:nth-child(2)": {
                "-webkit-transform": "rotate(45deg)",
                "transform": "rotate(45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(3)": {
                "-webkit-transform": "rotate(-45deg)",
                "transform": "rotate(-45deg)",
                "transition": "all 0.25s"
              },
              "&:nth-child(4)": {
                "top": "8px",
                "width": "0",
                "opacity": "0",
                "right": "50%",
                "transition": "all 0.2s"
              }
            },
            ".navbar-dropdown": {
              "padding": "0.5rem 1rem",
              "& when (@sticky)": {
                "position": "fixed"
              }
            },
            ".mbr-iconfont": {
              "font-size": "1.5rem",
              "padding-right": "0.5rem"
            },
            ".icons-menu": {
              "text-align": "inherit",
              "span": {
                "font-size": "20px",
                "color": "#232323"
              },
              "margin-right": "20px"
            },
            ".nav-link:hover, .dropdown-item:hover, .icons-menu .mbr-iconfont:hover": {
              "color": "@itemsHoverColor !important"
            },
            "@media screen and (~'-ms-high-contrast: active'), (~'-ms-high-contrast: none')": {
              ".navbar": {
                "height": "77px",
                "&.opened": {
                  "height": "auto"
                }
              }
            },
            "@media (max-width: 767px)": {
              ".navbar-collapse .img-column": {
                "display": "none"
              },
              ".icons-menu, .navbar-buttons, .contact-block, .text-column": {
                "text-align": "center !important"
              }
            },
            "h6.mbr-fonts-style": {
              "padding": "0"
            },
            ".collapsing": {
              "transition": "0s"
            },
            ".flex-container": {
              "height": "100%",
              "width": "100%"
            },
            "@media (min-width: 769px)": {
              ".flex-container": {
                "display": "flex",
                "flex-direction": "column"
              },
              ".flex-row": {
                "display": "flex",
                "flex-wrap": "wrap",
                "justify-content": "center",
                "width": "100%"
              },
              ".flex-row.low-row": {
                "align-items": "flex-end",
                "flex": "1 1 auto"
              },
              ".flex-card": {
                "display": "flex",
                "flex-direction": "column",
                "& h6": {
                  "padding": ".5rem 1rem"
                }
              },
              ".contact-block": {
                "margin-left": "20px"
              },
              ".contact-block ul li": {
                "text-align": "left"
              },
              "ul.col": {
                "padding": "0"
              },
              "& when (@showIcons) and (@showContacts)": {
                ".flex-row.low-row": {
                  "justify-content": "space-between"
                }
              }
            },
            ".icons-menu,.navbar-buttons,.contact-block,.text-column": {
              "color": "#000000"
            },
            "& when (@showIcons)": {
              ".icons-menu a span": {
                "color": "@iconsColor"
              }
            },
            "H6": {
              "color": "#fb8600",
              "text-align": "left"
            }
          },
          "_cid": "ufKLLFkzx1",
          "_anchor": "menu1-o",
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".card-subtitle": {
              "margin": "0"
            },
            ".card-img": {
              "z-index": "2",
              "position": "relative",
              "width": "100%",
              "transition": "all 0.3s",
              "padding-top": "2rem",
              "img": {
                "max-width": "200px",
                "margin-left": "auto",
                "margin-right": "auto"
              }
            },
            ".icon": {
              "width": "60px",
              "height": "60px",
              "background": "@iconbgColor",
              "font-size": "1.2rem",
              "transform": "translatey(1.2rem)",
              "margin": "auto",
              "border-radius": "50%",
              "justify-content": "center",
              "align-items": "center",
              "display": "flex",
              "color": "@iconColor !important"
            },
            ".item-wrapper": {
              "position": "relative",
              "svg": {
                "position": "absolute",
                "width": "100%",
                "top": "0",
                "left": "0",
                "z-index": "0",
                "path": {
                  "fill": "@cardBg",
                  "transition": "all 0.3s",
                  "stroke": "@svgborder"
                }
              },
              "padding": "1rem",
              "border-radius": "9px",
              "transition": "all 0.3s",
              "cursor": "pointer",
              "overflow": "visible"
            },
            "h4, h6, h5": {
              "margin": "0"
            },
            ".mbr-text": {
              "transition": "all 0.3s"
            },
            ".btn-white-outline": {
              "color": "@primaryColor !important"
            },
            ".card-box": {
              "z-index": "1",
              "position": "relative"
            },
            ".price": {
              "color": "#0e0e0e",
              "transition": "all 0.3s"
            },
            "img": {
              "transition": "all 0.3s",
              "width": "170px",
              "height": "170px",
              "object-fit": "cover"
            },
            ".card": {
              "cursor": "pointer",
              "transition": "all 0.3s",
              "max-width": "291px",
              "margin-bottom": "4rem",
              "&:hover": {
                "transform": "translateY(-2rem)",
                ".item-wrapper": {
                  "color": "@cardHoverText !important",
                  ".price": {
                    "color": "@cardHoverText !important"
                  },
                  ".mbr-text": {
                    "color": "@cardHoverText !important"
                  },
                  "path": {
                    "fill": "@cardHoverBg"
                  }
                }
              }
            },
            ".row": {
              "justify-content": "center"
            },
            "@media (max-width: 992px)": {
              ".wrapper": {
                "flex-direction": "column"
              },
              ".icon-padding": {
                "padding-left": "0rem"
              },
              ".card-box": {
                "padding": "0"
              }
            },
            ".mbr-text, .mbr-section-btn, .card-img": {
              "color": "#808080"
            },
            "H2": {
              "color": "#ff7300"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_name": "pricing02",
          "_sourceTheme": "dinerm4",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"pricing02 dinerm4_pricing02\" group=\"Pricing\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n\t<mbr-parameters>\n\t\t\n\t\t<header>Size</header>\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"8\">\n\t\t<select title=\"Cards\" name=\"cardsAmount\">\n\t\t\t<option value=\"1\">1</option>\n\t\t\t<option value=\"2\">2</option>\n\t\t\t<option value=\"3\">3</option>\n\t\t\t<option value=\"4\" selected>4</option>\n\t\t</select>\n\t\t<header>Show / Hide</header>\n\t\t<input type=\"checkbox\" title=\"Main Subtitle\" name=\"showSubTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Main Title\" name=\"showmainTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\t\t<input type=\"checkbox\" title=\"Price\" name=\"showPrice\">\n\t\t<header>Color</header>\n\t\t<input type=\"color\" title=\"Card\" name=\"cardBg\" value=\"#ffffff\" selected>\n\t\t<input type=\"color\" title=\"Card Border\" name=\"svgborder\" value=\"#cccccc\" selected>\n\t\t<input type=\"color\" title=\"Icon\" name=\"iconColor\" value=\"#0e0e0e\" selected>\n\t\t<input type=\"color\" title=\"Icon BG\" name=\"iconbgColor\" value=\"#fbbe36\" selected>\n\t\t<input type=\"color\" title=\"Card Hover BG\" name=\"cardHoverBg\" value=\"#fb8600\" selected>\n\t\t<input type=\"color\" title=\"Card Hover Text\" name=\"cardHoverText\" value=\"#ffffff\" selected>\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/dinerm4/components/_images/background1.jpg\" parallax>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n\t\t</fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/dinerm4/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#efefef\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n\t\t\n\t</mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n\t</div>\n\t<div class=\"container\">\n\t\t<div class=\"row\">\n\n\t\t\t<div class=\"col-md-12 pb-5 col-lg-12 align-center\">\n\t\t\t\t<h2 class=\"mbr-section-subtitle mbr-exbold mbr-light mbr-fonts-style\" mbr-if=\"showSubTitle\" mbr-theme-style=\"display-5\">Making good changes in the society..</h2>\n\t\t\t\t<h1 class=\"mbr-section-title pb-3 mbr-exbold mbr-fonts-style\" mbr-if=\"showmainTitle\" mbr-theme-style=\"display-2\">Our Products</h1>\n\t\t\t</div>\n\t\t\t<div class=\"card item features-image col-12 col-md-6\" mbr-if=\"cardsAmount > 1\" mbr-class=\"{'col-lg-3': cardsAmount == '4',\n                             'col-lg-4': cardsAmount == '3'}\">\n\t\t\t\t<div class=\"item-wrapper align-center\">\n\n\t\t\t\t\t<div class=\"card-img\">\n\t\t\t\t\t\t<img src=\"@PROJECT_PATH@/assets/images/ptc-225x225.png\" alt=\"PTC\">\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<svg xmlns=\"http://www.w3.org/2000/svg\" id=\"Layer_1\" data-name=\"Layer 1\" viewBox=\"0 0 254.99 483.96\" class=\"product-shape-hover-img\" src=\"http://demo.themewinter.com/wp/gloreya/wp-content/themes/gloreya/assets/images/menu_shape_hover.svg\" alt=\"Quarter Onion\">\n\t\t\t\t\t\t<path stroke=\"lightgray\" d=\"M235.35,0H19.64A19.61,19.61,0,0,0,0,19.59V423.24a19.62,19.62,0,0,0,19.64,19.6H53.4l-1,.09a45.89,45.89,0,0,1,32,12.15c6.73,6.28,11.46,14.52,18.55,20.4,13.23,11,34.19,11.33,47.78.79,7.07-5.49,12-13.26,18.32-19.56,8.81-8.75,21-14.67,33.42-13.73l-1.43-.14h34.23A19.62,19.62,0,0,0,255,423.24V19.59A19.61,19.61,0,0,0,235.35,0Z\">\n\t\t\t\t\t\t</path>\n\t\t\t\t\t</svg>\n\n\t\t\t\t\t<div class=\"card-box pt-4\">\n\n\n\n\n\t\t\t\t\t\t<h4 class=\"card-title pb-3 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-img\">PTC</h4>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn, .card-img\">\n\t\t\t\t\t\t\tParivartan the change<br>NGO</p>\n\n\t\t\t\t\t\t<h5 class=\"price pb-4 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showPrice\" data-app-selector=\".price\">$ 12</h5>\n\n\n\t\t\t\t\t\t<a href=\"https://www.parivartanthechange.org/\" target=\"_blank\"><span mbr-icon class=\"icon mbr-iconfont mbr-iconfont-btn socicon-teamviewer socicon\"></span></a>\n\n\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"card item features-image col-12 col-md-6\" mbr-class=\"{'col-lg-3': cardsAmount == '4',\n                             'col-lg-4': cardsAmount == '3'}\">\n\t\t\t\t<div class=\"item-wrapper align-center\">\n\n\t\t\t\t\t<div class=\"card-img\">\n\t\t\t\t\t\t<img src=\"@ADDONS_PATH@/dinerm4/components/_images/img/05.png\" alt=\"Mobirise\">\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<svg xmlns=\"http://www.w3.org/2000/svg\" id=\"Layer_1\" data-name=\"Layer 1\" viewBox=\"0 0 254.99 483.96\" class=\"product-shape-hover-img\" src=\"http://demo.themewinter.com/wp/gloreya/wp-content/themes/gloreya/assets/images/menu_shape_hover.svg\" alt=\"Quarter Onion\">\n\t\t\t\t\t\t<path stroke=\"lightgray\" d=\"M235.35,0H19.64A19.61,19.61,0,0,0,0,19.59V423.24a19.62,19.62,0,0,0,19.64,19.6H53.4l-1,.09a45.89,45.89,0,0,1,32,12.15c6.73,6.28,11.46,14.52,18.55,20.4,13.23,11,34.19,11.33,47.78.79,7.07-5.49,12-13.26,18.32-19.56,8.81-8.75,21-14.67,33.42-13.73l-1.43-.14h34.23A19.62,19.62,0,0,0,255,423.24V19.59A19.61,19.61,0,0,0,235.35,0Z\">\n\t\t\t\t\t\t</path>\n\t\t\t\t\t</svg>\n\n\t\t\t\t\t<div class=\"card-box pt-4\">\n\n\n\n\n\t\t\t\t\t\t<h4 class=\"card-title pb-3 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-img\">Mozzarella Pizza</h4>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn, .card-img\">\n\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur adipiscing.</p>\n\n\t\t\t\t\t\t<h5 class=\"price pb-4 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showPrice\" data-app-selector=\".price\">$ 14</h5>\n\n\n\t\t\t\t\t\t<span mbr-icon class=\"icon mobi-mbri mobi-mbri-cart-full mbr-iconfont mbr-iconfont-btn\"></span>\n\n\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<div class=\"card item features-image col-12 col-md-6\" mbr-if=\"cardsAmount > 2\" mbr-class=\"{'col-lg-3': cardsAmount == '4',\n                             'col-lg-4': cardsAmount == '3'}\">\n\t\t\t\t<div class=\"item-wrapper align-center\">\n\n\t\t\t\t\t<div class=\"card-img\">\n\t\t\t\t\t\t<img src=\"@ADDONS_PATH@/dinerm4/components/_images/img/03.png\" alt=\"Mobirise\">\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<svg xmlns=\"http://www.w3.org/2000/svg\" id=\"Layer_1\" data-name=\"Layer 1\" viewBox=\"0 0 254.99 483.96\" class=\"product-shape-hover-img\" src=\"http://demo.themewinter.com/wp/gloreya/wp-content/themes/gloreya/assets/images/menu_shape_hover.svg\" alt=\"Quarter Onion\">\n\t\t\t\t\t\t<path stroke=\"lightgray\" d=\"M235.35,0H19.64A19.61,19.61,0,0,0,0,19.59V423.24a19.62,19.62,0,0,0,19.64,19.6H53.4l-1,.09a45.89,45.89,0,0,1,32,12.15c6.73,6.28,11.46,14.52,18.55,20.4,13.23,11,34.19,11.33,47.78.79,7.07-5.49,12-13.26,18.32-19.56,8.81-8.75,21-14.67,33.42-13.73l-1.43-.14h34.23A19.62,19.62,0,0,0,255,423.24V19.59A19.61,19.61,0,0,0,235.35,0Z\">\n\t\t\t\t\t\t</path>\n\t\t\t\t\t</svg>\n\n\t\t\t\t\t<div class=\"card-box pt-4\">\n\n\n\n\n\t\t\t\t\t\t<h4 class=\"card-title pb-3 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-img\">Thai Combo</h4>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn, .card-img\">\n\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur adipiscing.</p>\n\n\t\t\t\t\t\t<h5 class=\"price pb-4 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showPrice\" data-app-selector=\".price\">$ 12</h5>\n\n\n\t\t\t\t\t\t<span mbr-icon class=\"icon mobi-mbri mobi-mbri-cart-full mbr-iconfont mbr-iconfont-btn\"></span>\n\n\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\n\t\t\t<div class=\"card item features-image col-12 col-md-6\" mbr-if=\"cardsAmount > 3\" mbr-class=\"{'col-lg-3': cardsAmount == '4',\n                             'col-lg-4': cardsAmount == '3'}\">\n\t\t\t\t<div class=\"item-wrapper align-center\">\n\n\t\t\t\t\t<div class=\"card-img\">\n\t\t\t\t\t\t<img src=\"@ADDONS_PATH@/dinerm4/components/_images/img/05.png\" alt=\"Mobirise\">\n\t\t\t\t\t</div>\n\n\t\t\t\t\t<svg xmlns=\"http://www.w3.org/2000/svg\" id=\"Layer_1\" data-name=\"Layer 1\" viewBox=\"0 0 254.99 483.96\" class=\"product-shape-hover-img\" src=\"http://demo.themewinter.com/wp/gloreya/wp-content/themes/gloreya/assets/images/menu_shape_hover.svg\" alt=\"Quarter Onion\">\n\t\t\t\t\t\t<path stroke=\"lightgray\" d=\"M235.35,0H19.64A19.61,19.61,0,0,0,0,19.59V423.24a19.62,19.62,0,0,0,19.64,19.6H53.4l-1,.09a45.89,45.89,0,0,1,32,12.15c6.73,6.28,11.46,14.52,18.55,20.4,13.23,11,34.19,11.33,47.78.79,7.07-5.49,12-13.26,18.32-19.56,8.81-8.75,21-14.67,33.42-13.73l-1.43-.14h34.23A19.62,19.62,0,0,0,255,423.24V19.59A19.61,19.61,0,0,0,235.35,0Z\">\n\t\t\t\t\t\t</path>\n\t\t\t\t\t</svg>\n\n\t\t\t\t\t<div class=\"card-box pt-4\">\n\n\n\n\n\t\t\t\t\t\t<h4 class=\"card-title pb-3 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showTitle\" data-app-selector=\".card-title, .card-img\">Mozzarella Pizza</h4>\n\t\t\t\t\t\t<p class=\"mbr-text mbr-semibold mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn, .card-img\">\n\t\t\t\t\t\t\tLorem ipsum dolor sit amet, consectetur adipiscing.</p>\n\n\t\t\t\t\t\t<h5 class=\"price pb-4 mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showPrice\" data-app-selector=\".price\">$ 14</h5>\n\n\n\t\t\t\t\t\t<span mbr-icon class=\"icon mobi-mbri mobi-mbri-cart-full mbr-iconfont mbr-iconfont-btn\"></span>\n\n\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\n\n\t\t</div>\n\t</div>\n\n</section>",
