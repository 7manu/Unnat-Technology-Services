        },
        {
          "_name": "aheader2",
          "_sourceTheme": "mediam5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header2 mediam5 mbr-fullscreen\" group=\"Headers\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Image Bg\" name=\"showImgBg\" checked>\n        <input type=\"color\" title=\"Image Bg Color\" name=\"iconBg\" value=\"#FACB1D\" condition=\"showImgBg\">\n        <input type=\"range\" inline name=\"iconOpacity\" title=\"Image Bg Opacity\" min=\"0\" max=\"1\" value=\"0.33\" step=\"0.01\" condition=\"showImgBg\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/mediam5/components/_images/background2.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#edefeb\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/mediam5/components/_images/background2.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#f6f6ef\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div class=\"img-bg\" mbr-if=\"showImgBg\"></div>\n    <div class=\"container\">\n        <div class=\"row justify-content-center align-items-center\">\n            <div class=\"col-12 col-lg-5 col-text\">\n                <div class=\"text-wrapper\">\n                    <h1 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-1\" mbr-if=\"showTitle\">WHO WE ARE ?</h1>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" mbr-if=\"showText\" data-app-selector=\".mbr-text, .mbr-section-btn\">\n                        Unnat Technology Services is a premier technology solutions provider based in India, specializing in delivering innovative and customized technological solutions to a diverse clientele. With a focus on enhancing business efficiency and driving digital transformation, Unnat Technology Services stands out as a trusted partner for organizations seeking to leverage technology for sustainable growth.\n                    </p>\n                    <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\"><a class=\"btn btn-primary\" href=\"products.php\" data-app-placeholder=\"Type Text\"><span class=\"mdi-action-info mbr-iconfont mbr-iconfont-btn\"></span>Our Products</a></div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-7 col-img\">\n                <div class=\"image-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/uts-logo-removebg-removebg-preview-512x512.png\" alt=\"UTS\">\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "position": "relative",
            "overflow": "hidden",
            "display": "flex",
            "flex-direction": "column",
            "justify-content": "center",
            "margin-top": "5rem",
            "@media (max-width: 991px)": {
              "padding-bottom": "0 !important"
            },
            ".container": {
              "position": "static",
              "@media (max-width: 991px)": {
                "flex-grow": "1",
                "display": "flex",
                "flex-direction": "column"
              }
            },
            ".row": {
              "@media (max-width: 991px)": {
                "flex-grow": "1",
                "display": "flex",
                "flex-direction": "column"
              }
            },
            ".text-wrapper": {
              "position": "relative",
              "z-index": "4",
              "margin-bottom": "10rem",
              "@media (max-width: 991px)": {
                "max-width": "560px",
                "width": "100%",
                "margin-right": "auto"
              }
            },
            ".mbr-section-title": {
              "color": "#fb8600",
              "margin-bottom": "2rem"
            },
            ".mbr-text": {
              "color": "#181817",
              "margin-bottom": "1rem"
            },
            ".mbr-section-btn": {
              "margin-top": "24px"
            },
            ".col-img": {
              "@media (max-width: 991px)": {
                "margin-top": "auto"
              },
              "@media (max-width: 575px)": {
                "padding": "0 !important"
              }
            },
            ".image-wrapper": {
              "display": "flex",
              "align-items": "flex-end",
              "position": "absolute",
              "right": "0",
              "bottom": "0",
              "z-index": "3",
              "width": "55%",
              "height": "100%",
              "img": {
                "object-fit": "cover",
                "height": "300px",
                "width": "265px"
              },
              "@media (max-width: 991px)": {
                "position": "relative",
                "width": "90%",
                "margin-left": "auto",
                "margin-right": "-2rem",
                "@media (max-width: 767px)": {
                  "margin-right": "-1.5rem"
                },
                "@media (max-width: 575px)": {
                  "width": "100%",
                  "margin-right": "0",
                  "margin-left": "0"
                }
              }
            },
            ".img-bg": {
              "position": "absolute",
              "right": "-15%",
              "bottom": "-35%",
              "width": "65vw",
              "aspect-ratio": "(1 / 1)",
              "border-radius": "50%",
              "background": "rgba(red(@iconBg), green(@iconBg), blue(@iconBg), @iconOpacity)",
              "z-index": "2",
              "@media (max-width: 991px)": {
                "width": "1000px",
                "right": "-400px"
              },
              "@media (max-width: 767px)": {
                "width": "800px",
                "right": "-300px"
              },
              "@media (max-width: 575px)": {
                "width": "170vw",
                "right": "-75vw"
              }
            },
            ".mbr-text, .mbr-section-btn": {
              "text-align": "left"
            }
          },
