                "padding": "0 48px",
                "@media (max-width: 992px)": {
                  "padding": "0 16px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 16px"
              }
            },
            ".row": {
              "justify-content": "space-between"
            },
            ".content-wrapper": {
              "display": "flex",
              "flex-direction": "column",
              "justify-content": "space-between",
              "height": "100%",
              "@media (max-width: 992px)": {
                "height": "auto",
