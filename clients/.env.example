APP_NAME="Unnat Technology Services"
APP_URL=http://localhost:8000
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata

MONGODB_URI=<paste MongoDB URI here>
MONGODB_DATABASE=client_leads

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=<generate with php scripts/hash_admin_password.php "your-password">

MAIL_FROM=notifications@example.com
MAIL_FROM_NAME="Unnat Technology Services"

# Generate with: vendor/bin/web-push generate:vapid
VAPID_SUBJECT=mailto:admin@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
