{
  "name": "uts/client-leads",
  "description": "PHP MongoDB project and client lead dashboard with PWA notifications.",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "mongodb/mongodb": "^2.0",
    "minishlink/web-push": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "process-timeout": 0
  },
  "scripts": {
    "serve": [
      "Composer\\Config::disableProcessTimeout",
      "php -S localhost:8000 -t public"
    ],
    "notify": "php scripts/send_meeting_notifications.php"
  }
}
